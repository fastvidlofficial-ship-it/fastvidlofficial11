# =====================================================================
# Blog Management — environment variables
# Copy this file to `.env.local` and fill in real values.
# .env.local is gitignored by default in Next.js projects.
# =====================================================================

# MongoDB connection string (e.g. from MongoDB Atlas free tier).
# Format: mongodb+srv://<user>:<pass>@<cluster>/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/fastvidl

# Long random string used to sign admin session JWTs.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string-at-least-32-chars

# Admin login credentials (used by /admin-dashboard/login).
ADMIN_EMAIL=admin@fastvidl.com
ADMIN_PASSWORD=admin@fastvidl

# Optional: TinyMCE Cloud API key (free at https://www.tiny.cloud).
# Without a key the editor still works in dev but shows a small banner.
NEXT_PUBLIC_TINYMCE_API_KEY=no-api-key

# Required in production for image uploads on Vercel.
# Create a public Blob store in your Vercel dashboard, then copy its
# read-write token here (Project -> Storage -> Blob -> .env.local snippet).
# Local development can fall back to public/uploads/blogs/ if this is omitted.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxx

# Public site origin — used by blog metadata for absolute URLs.
NEXT_PUBLIC_SITE_URL=https://fastvidl.com

# Web3Forms access key for /contact-us (https://web3forms.com).
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
